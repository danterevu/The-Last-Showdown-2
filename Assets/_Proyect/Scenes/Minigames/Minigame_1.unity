  m_Name: 
  m_EditorClassIdentifier: 
  panels:
  - {fileID: 1444270754}
  - {fileID: 865610651}
  pools:
  - trigger: 0
    comments:
    - "Saben... no es tan dif\xEDcil esta fase"
    - No se desanimen que esquivar nunca fue tan divertido!
    - Espero que no les sea tan doloroso que los corten por la mitad
    displayDuration: 3
  - trigger: 2
    comments:
    - Nuestra audiencia ama los power ups! ...aunque a veces fallen
    displayDuration: 3
  - trigger: 1
    comments:
    - espero que disfruten los power ups! fueron agregados esta temporada
    - mas chances para sumar puntos, que emocion!
    - Por lo menos sus muertes serviran de algo... para su rival!
    - Cada chance de sumar puntos es una chance de sobrevivir
    displayDuration: 3
