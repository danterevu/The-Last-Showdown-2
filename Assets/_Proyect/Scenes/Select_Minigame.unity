    defaultPresenterSprite: {fileID: -6291641308854743428, guid: 5e05f5154ebb59349b81cec8da6b2ab7, type: 3}
    keepLastSprite: 0
    postSequenceSprite: {fileID: 0}
    lines:
    - text: 'Desearia tirar la ruleta '
      presenterSprite: {fileID: 5461972331887365146, guid: a1b373708ed20db45a1cbb44891a25d5, type: 3}
      displayDuration: 4
      isFinalDialogue: 0
    - text: 'Pero dame un pedazo de ese chocolate '
      presenterSprite: {fileID: -4726644080215648741, guid: 6732a827b5d440649be042b46bf9254e, type: 3}
      displayDuration: 5
      isFinalDialogue: 1
  returnSequencesByMinigame:
  - minigameId: 1
    minigameName: DodgeDisk
    sequences:
    - sequenceName: Normal
      defaultPresenterSprite: {fileID: 0}
      keepLastSprite: 0
      postSequenceSprite: {fileID: 0}
      lines:
      - text: Mamita que espectaculo! ni en las tierras de alabama vi tantas habilidades
          de esquivar!
        presenterSprite: {fileID: 0}
        displayDuration: 5
        isFinalDialogue: 0
      - text: Pero bueno.. ahora que presenciamos ese espectaculo, que tal si pasamos
          a otra ronda?
        presenterSprite: {fileID: 0}
        displayDuration: 5
        isFinalDialogue: 1
    - sequenceName: Locura
      defaultPresenterSprite: {fileID: 0}
      keepLastSprite: 0
      postSequenceSprite: {fileID: 0}
      lines:
      - text: Eso fue una completa porqueria! Para ser los mas capacitados, lo hicieron
          completamente fatal! como van a salvar su propio culo si no saben esquivar
          una maldita bola
        presenterSprite: {fileID: -4726644080215648741, guid: 6732a827b5d440649be042b46bf9254e, type: 3}
        displayDuration: 5
        isFinalDialogue: 0
      - text: 'Vayamos al final de esto '
        presenterSprite: {fileID: 0}
        displayDuration: 5
        isFinalDialogue: 1
  - minigameId: 2
    minigameName: KOH
    sequences:
    - sequenceName: 'Normal '
      defaultPresenterSprite: {fileID: -6291641308854743428, guid: 5e05f5154ebb59349b81cec8da6b2ab7, type: 3}
      keepLastSprite: 1
      postSequenceSprite: {fileID: 5461972331887365146, guid: a1b373708ed20db45a1cbb44891a25d5, type: 3}
      lines:
      - text: Que forma de agarrarse a golpes con tal de ganar unos puntos, eso si
          es un verdadero concurso por la excelencia de cada uno!
        presenterSprite: {fileID: -7568444368513293514, guid: 81a9f4faf9ee38948b53fd0e70db40e0, type: 3}
        displayDuration: 5
        isFinalDialogue: 0
      - text: Ahora que hemos concluido con esta increible ronda, que tal si pasamos
          al siguiente minijuego?
        presenterSprite: {fileID: 5461972331887365146, guid: a1b373708ed20db45a1cbb44891a25d5, type: 3}
        displayDuration: 5
        isFinalDialogue: 1
    - sequenceName: Locura
      defaultPresenterSprite: {fileID: -4726644080215648741, guid: 6732a827b5d440649be042b46bf9254e, type: 3}
      keepLastSprite: 1
      postSequenceSprite: {fileID: 5461972331887365146, guid: a1b373708ed20db45a1cbb44891a25d5, type: 3}
      lines:
      - text: 'Si tuviera que elegir entre torturar a uno de mis espectadores o eliminar
          a uno de estos dos jugadores, definitivamente ACABARIA EL JUEGO '
        presenterSprite: {fileID: -4726644080215648741, guid: 6732a827b5d440649be042b46bf9254e, type: 3}
        displayDuration: 5
        isFinalDialogue: 0
      - text: 'Sigamos con el programa '
        presenterSprite: {fileID: -7568444368513293514, guid: 81a9f4faf9ee38948b53fd0e70db40e0, type: 3}
        displayDuration: 5
        isFinalDialogue: 1
  - minigameId: 3
    minigameName: DNA
    sequences:
    - sequenceName: 'Normal '
      defaultPresenterSprite: {fileID: -6291641308854743428, guid: 5e05f5154ebb59349b81cec8da6b2ab7, type: 3}
      keepLastSprite: 1
      postSequenceSprite: {fileID: 5461972331887365146, guid: a1b373708ed20db45a1cbb44891a25d5, type: 3}
      lines:
      - text: 'Pero que cambios tan abruptos en el panorama! Cajas? Mutaciones? Que
          espectaculo nos dieron! '
        presenterSprite: {fileID: -6291641308854743428, guid: 5e05f5154ebb59349b81cec8da6b2ab7, type: 3}
        displayDuration: 5
        isFinalDialogue: 0
      - text: Ahora que acabamos con estas mutaciones, que tal si vamos a la siguiente
          ronda?
        presenterSprite: {fileID: 5461972331887365146, guid: a1b373708ed20db45a1cbb44891a25d5, type: 3}
        displayDuration: 5
        isFinalDialogue: 1
    - sequenceName: Locura
      defaultPresenterSprite: {fileID: -4726644080215648741, guid: 6732a827b5d440649be042b46bf9254e, type: 3}
      keepLastSprite: 1
      postSequenceSprite: {fileID: 5461972331887365146, guid: a1b373708ed20db45a1cbb44891a25d5, type: 3}
      lines:
      - text: Si me dieran una Zipzomoneda por todas las veces que estos dos fracasados
          no llegaron a entregar ni una sola muestra, TENDRIA MAS DE 10
        presenterSprite: {fileID: -4726644080215648741, guid: 6732a827b5d440649be042b46bf9254e, type: 3}
        displayDuration: 5
        isFinalDialogue: 0
      - text: 'Mi paciencia se esta colmando, los espectadores estan bajando, si
          no hacen una buena actuacion, pronto van a encontrar mi ira, vamos con
          la ruleta '
        presenterSprite: {fileID: -4726644080215648741, guid: 6732a827b5d440649be042b46bf9254e, type: 3}
        displayDuration: 5
        isFinalDialogue: 1
  - minigameId: 4
    minigameName: Space
    sequences:
    - sequenceName: 'Normal '
      defaultPresenterSprite: {fileID: -6291641308854743428, guid: 5e05f5154ebb59349b81cec8da6b2ab7, type: 3}
      keepLastSprite: 1
      postSequenceSprite: {fileID: 5461972331887365146, guid: a1b373708ed20db45a1cbb44891a25d5, type: 3}
      lines:
      - text: Que forma de volar esos obstaculos! no me queda duda que ustedes son
          unos expertos
        presenterSprite: {fileID: -6291641308854743428, guid: 5e05f5154ebb59349b81cec8da6b2ab7, type: 3}
        displayDuration: 5
        isFinalDialogue: 0
      - text: 'Vamos al siguiente minijuego! '
        presenterSprite: {fileID: 5461972331887365146, guid: a1b373708ed20db45a1cbb44891a25d5, type: 3}
        displayDuration: 5
        isFinalDialogue: 1
    - sequenceName: Locura
      defaultPresenterSprite: {fileID: -4726644080215648741, guid: 6732a827b5d440649be042b46bf9254e, type: 3}
      keepLastSprite: 1
      postSequenceSprite: {fileID: 5461972331887365146, guid: a1b373708ed20db45a1cbb44891a25d5, type: 3}
      lines:
      - text: No saben ni saltar un MALDITO obstaculo, que pensara el publico de
          ustedes cuando tenga que ELIMINARLOS A LOS DOS
        presenterSprite: {fileID: -4726644080215648741, guid: 6732a827b5d440649be042b46bf9254e, type: 3}
        displayDuration: 5
        isFinalDialogue: 0
      - text: 'Que lastima que ustedes nazcan y mueran sin ver la luz del sol '
        presenterSprite: {fileID: -4726644080215648741, guid: 6732a827b5d440649be042b46bf9254e, type: 3}
        displayDuration: 5
        isFinalDialogue: 1
  - minigameId: 5
    minigameName: ChaseRun
    sequences:
    - sequenceName: 'Normal '
      defaultPresenterSprite: {fileID: -6291641308854743428, guid: 5e05f5154ebb59349b81cec8da6b2ab7, type: 3}
      keepLastSprite: 1
      postSequenceSprite: {fileID: 5461972331887365146, guid: a1b373708ed20db45a1cbb44891a25d5, type: 3}
      lines:
      - text: Que forma de sobrevolar a base de tiros y powerUps!
        presenterSprite: {fileID: -6291641308854743428, guid: 5e05f5154ebb59349b81cec8da6b2ab7, type: 3}
        displayDuration: 5
        isFinalDialogue: 0
      - text: 'Vamos al siguiente minijuego! '
        presenterSprite: {fileID: 5461972331887365146, guid: a1b373708ed20db45a1cbb44891a25d5, type: 3}
        displayDuration: 5
        isFinalDialogue: 1
    - sequenceName: Locura
      defaultPresenterSprite: {fileID: -4726644080215648741, guid: 6732a827b5d440649be042b46bf9254e, type: 3}
      keepLastSprite: 1
      postSequenceSprite: {fileID: 5461972331887365146, guid: a1b373708ed20db45a1cbb44891a25d5, type: 3}
      lines:
      - text: Que desastre...
        presenterSprite: {fileID: -4726644080215648741, guid: 6732a827b5d440649be042b46bf9254e, type: 3}
        displayDuration: 5
        isFinalDialogue: 0
      - text: 'Van a morir aqui '
        presenterSprite: {fileID: -4726644080215648741, guid: 6732a827b5d440649be042b46bf9254e, type: 3}
        displayDuration: 5
        isFinalDialogue: 1
  minigameResultDialogues:
  - minigameId: 1
    minigameName: DodgeDisk
    sequences:
    - sequenceName: Comentario1
      defaultPresenterSprite: {fileID: 0}
      keepLastSprite: 0
      postSequenceSprite: {fileID: 0}
      lines:
      - text: Parece que Dodge Disk fue el elegido esta vez!
        presenterSprite: {fileID: 0}
        displayDuration: 2
        isFinalDialogue: 0
      - text: Les dare una pista de lo que consiste.. el resto lo averiguaran ustedes!
        presenterSprite: {fileID: 0}
        displayDuration: 3
        isFinalDialogue: 0
      - text: En lo frio del hielo y el azul del neon, una amigable sierra se acercara
          a ustedes a darle una calida bienvenida! vamos a los modificadores
        presenterSprite: {fileID: 0}
        displayDuration: 5
        isFinalDialogue: 1
  - minigameId: 2
    minigameName: King of HIll
    sequences:
    - sequenceName: 'Bienvenida '
      defaultPresenterSprite: {fileID: 0}
      keepLastSprite: 0
      postSequenceSprite: {fileID: 0}
      lines:
      - text: El Rey de la Colina fue el elegido para iniciar el siguiente juego!
        presenterSprite: {fileID: 0}
        displayDuration: 3
        isFinalDialogue: 0
      - text: Les dare una pista para la siguiente ronda
        presenterSprite: {fileID: 0}
        displayDuration: 3
        isFinalDialogue: 0
      - text: En campos de juego... laseres por monton, un punto a controlar y a
          golpes se deberan de arreglar! vamos a la ruleta de modificadores!
        presenterSprite: {fileID: 0}
        displayDuration: 4
        isFinalDialogue: 1
  - minigameId: 3
    minigameName: DNA
    sequences:
    - sequenceName: 
      defaultPresenterSprite: {fileID: 0}
      keepLastSprite: 0
      postSequenceSprite: {fileID: 0}
      lines:
      - text: DNA disponible para entrar a la accion! ese fue el minijuego elegido
          por la ruleta de la desolacion
        presenterSprite: {fileID: 0}
        displayDuration: 3
        isFinalDialogue: 0
      - text: "Peleen para llenar esos frascos y esperen efectos varios a la hora
          de encontrarse con nuevos cambios... \n"
        presenterSprite: {fileID: 0}
        displayDuration: 3
        isFinalDialogue: 0
      - text: 'No olviden mi nueva implementacion, cajas por monton, no olviden de
          darles uso, que para eso son, vamos a la ruletade modificadores!

'
        presenterSprite: {fileID: 0}
        displayDuration: 5
        isFinalDialogue: 1
  - minigameId: 4
    minigameName: Space
    sequences:
    - sequenceName: Burning
      defaultPresenterSprite: {fileID: 0}
      keepLastSprite: 0
      postSequenceSprite: {fileID: 0}
      lines:
      - text: La suerte del destino nos dejo en medio del espacio, equipense con
          armas y detonen obstaculos
        presenterSprite: {fileID: 0}
        displayDuration: 2
        isFinalDialogue: 0
      - text: "Matense el uno al otro, en busca de la victoria, o torturen sus almas
          hasta volverse escoria \n\n"
        presenterSprite: {fileID: 0}
        displayDuration: 5
        isFinalDialogue: 0
      - text: Vamos a la ruleta de modificadores!
        presenterSprite: {fileID: 0}
        displayDuration: 3
        isFinalDialogue: 0
  - minigameId: 5
    minigameName: Chase
    sequences:
    - sequenceName: 
      defaultPresenterSprite: {fileID: 0}
      keepLastSprite: 0
      postSequenceSprite: {fileID: 0}
      lines: []
