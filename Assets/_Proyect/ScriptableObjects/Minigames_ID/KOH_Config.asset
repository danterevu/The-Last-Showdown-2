%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 00cd4e2d73764544cbd7da56366a0abb, type: 3}
  m_Name: KOH_Config
  m_EditorClassIdentifier: 
  id: 2
  displayName: King of The Hill
  resultColor: {r: 1, g: 0, b: 0.37736082, a: 1}
  modifiers:
  - displayName: ComeBack
    enumValue: 1
    resultDialogues:
    - sequenceName: Comeback
      defaultPresenterSprite: {fileID: 0}
      keepLastSprite: 0
      postSequenceSprite: {fileID: 0}
      lines:
      - text: Parece que esta vez vamos a ser buenos con los perdedores! Si uno de
          ustedes queda sin obtener muchos puntos, el presentador les va a salvar
          el pellejo si llegan a remontar!
        presenterSprite: {fileID: 0}
        displayDuration: 4
        isFinalDialogue: 0
      - text: 'Pero si no lo consiguen.. rindanse, no sirven para nada '
        presenterSprite: {fileID: 0}
        displayDuration: 2
        isFinalDialogue: 1
  - displayName: Bonus Hardpoint
    enumValue: 2
    resultDialogues:
    - sequenceName: Bonus Hardpoint Normal
      defaultPresenterSprite: {fileID: 0}
      keepLastSprite: 0
      postSequenceSprite: {fileID: 0}
      lines:
      - text: 'En esta decision tan especial, voy a aumentar la ganancia de puntos
          en la zona de control, preparense para pelear por esos puntos de una forma
          mas agresiva! '
        presenterSprite: {fileID: 0}
        displayDuration: 4
        isFinalDialogue: 0
      - text: 'Si no.. voy a tener que preparar la pala '
        presenterSprite: {fileID: 0}
        displayDuration: 4
        isFinalDialogue: 1
  - displayName: Point Bleed
    enumValue: 3
    resultDialogues:
    - sequenceName: Sangrado
      defaultPresenterSprite: {fileID: 0}
      keepLastSprite: 0
      postSequenceSprite: {fileID: 0}
      lines:
      - text: Me parece que los jugadores se van a desangrar si no se encuentran
          en ese punto, esfuercense por no perder todo lo conseguido!
        presenterSprite: {fileID: 0}
        displayDuration: 4
        isFinalDialogue: 0
      - text: Veamos que tal les va!
        presenterSprite: {fileID: 0}
        displayDuration: 3
        isFinalDialogue: 1
